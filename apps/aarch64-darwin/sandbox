#!/bin/sh -e

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

log()  { printf "${YELLOW}%s${NC}\n" "$*" >&2; }
ok()   { printf "${GREEN}%s${NC}\n" "$*" >&2; }
fail() { printf "${RED}%s${NC}\n" "$*" >&2; exit 1; }

# Locate the user's project. Worktree is created from here; if not in a git
# repo the sandbox refuses to start (no clean trust boundary otherwise).
INVOKED_FROM="${SANDBOX_INVOKED_FROM:-$PWD}"
cd "$INVOKED_FROM"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) \
  || fail "Not in a git repo. cd into one before running sandbox."

# Resolve the flake holding the devvm config. Default to this nix-config repo.
FLAKE="${SANDBOX_FLAKE:-$HOME/nix-config}"

REPO_NAME=$(basename "$REPO_ROOT")
TS=$(date +%Y%m%d-%H%M%S)
SANDBOX_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/nix-sandbox"
WORKTREE="$SANDBOX_ROOT/${REPO_NAME}-${TS}"
BRANCH="sandbox/${TS}"

SSH_PORT="${SANDBOX_SSH_PORT:-2222}"

# Per-session ssh authorized_keys built from host's ~/.ssh/*.pub AND any
# keys loaded in the host ssh-agent (covers Secretive / Secure Enclave keys
# that don't have a regular private file). The path is exported so devvm.nix
# can readFile it at eval time via builtins.getEnv (--impure).
SSH_KEY_DIR=$(mktemp -d "${TMPDIR:-/tmp}/devvm-keys.XXXXXXXX")
{
  for k in "$HOME"/.ssh/*.pub; do
    [ -f "$k" ] && cat "$k" && printf '\n'
  done
  ssh-add -L 2>/dev/null || true
} | awk 'NF && !seen[$0]++' > "$SSH_KEY_DIR/authorized_keys"
if [ ! -s "$SSH_KEY_DIR/authorized_keys" ]; then
  fail "No SSH public keys found in \$HOME/.ssh/*.pub or ssh-agent. Generate one with ssh-keygen, or unlock your agent."
fi
chmod 644 "$SSH_KEY_DIR/authorized_keys"
log "Authorized $(wc -l < "$SSH_KEY_DIR/authorized_keys" | tr -d ' ') key(s)."

export DEVVM_AUTHORIZED_KEYS_FILE="$SSH_KEY_DIR/authorized_keys"

log "Building devvm…"
INFO=$(nix --extra-experimental-features 'nix-command flakes' build \
  --impure --no-link --print-out-paths \
  "${FLAKE}#nixosConfigurations.devvm.config.system.build.devVmInfo")

KERNEL=$(jq -r .kernel        "$INFO")
INITRD=$(jq -r .initrd        "$INFO")
INIT=$(jq   -r .init          "$INFO")
KPARAMS_FILE=$(jq -r .kernelParamsFile "$INFO")
REGINFO=$(jq -r .regInfo      "$INFO")
BLANK_DISK=$(jq -r .blankDisk "$INFO")
SERIAL=$(jq  -r .serialConsole "$INFO")
SSH_USER=$(jq -r .sshUser     "$INFO")

# Also realise the toplevel/initrd/regInfo/blankDisk into the local store.
nix --extra-experimental-features 'nix-command flakes' build --impure --no-link \
  "${FLAKE}#nixosConfigurations.devvm.config.system.build.toplevel" \
  "${FLAKE}#nixosConfigurations.devvm.config.system.build.initialRamdisk" \
  "${FLAKE}#nixosConfigurations.devvm.config.system.build.devVmBlankDisk"

log "Creating worktree at $WORKTREE on branch $BRANCH"
mkdir -p "$SANDBOX_ROOT"
git -C "$REPO_ROOT" worktree add -b "$BRANCH" "$WORKTREE" >/dev/null

# No per-session disk image: -snapshot below makes QEMU open the backing
# qcow2 read-only and write all dirty blocks to a temp file in $TMPDIR,
# which it deletes on exit. macOS file cache means hot blocks stay in RAM.

SERIAL_LOG="$SSH_KEY_DIR/serial.log"

KPARAMS=$(cat "$KPARAMS_FILE")
APPEND="${KPARAMS} init=${INIT} regInfo=${REGINFO} console=${SERIAL},115200n8"

cleanup() {
  if [ -n "${QEMU_PID:-}" ] && kill -0 "$QEMU_PID" 2>/dev/null; then
    kill "$QEMU_PID" 2>/dev/null || true
    wait "$QEMU_PID" 2>/dev/null || true
  fi
  rm -rf "$SSH_KEY_DIR"
  # ssh -t leaves the terminal in raw mode and the remote shell emits CSI
  # device-status queries that the host terminal answers into stdin. Drain
  # those replies so the parent shell doesn't read them as command input.
  if [ -t 0 ]; then
    # Non-canonical, non-blocking read: time=1 (0.1s) min=0 → dd returns even
    # if no input is available.
    stty -icanon -echo min 0 time 1 2>/dev/null || true
    dd if=/dev/tty of=/dev/null bs=1024 count=1 2>/dev/null || true
    printf '\033[0m\033[?2004l\033[?1004l\033[?1l' 2>/dev/null || true
    stty sane 2>/dev/null || true
  fi
  ok ""
  ok "Sandbox session ended."
  ok "Worktree: $WORKTREE  (branch $BRANCH)"
  ok "Diff: git -C \"$REPO_ROOT\" diff $BRANCH"
  ok "Drop: git -C \"$REPO_ROOT\" worktree remove --force \"$WORKTREE\" && git -C \"$REPO_ROOT\" branch -D $BRANCH"
}
trap cleanup EXIT INT TERM

log "Booting QEMU on hvf (port $SSH_PORT → 22)…"

# Keep QEMU args co-located so swapping accel (hvf → vmapple) or fs sharing
# (9p → virtiofs) later is a localised change.
QEMU_BIN="qemu-system-aarch64"
QEMU_MACHINE="virt,accel=hvf,gic-version=3,highmem=on"
QEMU_CPU="host"

"$QEMU_BIN" \
  -name devvm \
  -machine "$QEMU_MACHINE" \
  -cpu "$QEMU_CPU" \
  -m 4096 \
  -smp 4 \
  -display none \
  -monitor none \
  -serial "file:${SERIAL_LOG}" \
  -device virtio-rng-pci \
  -netdev "user,id=net0,hostfwd=tcp:127.0.0.1:${SSH_PORT}-:22" \
  -device virtio-net-pci,netdev=net0 \
  -snapshot \
  -drive "file=${BLANK_DISK},if=none,id=drive0,format=qcow2" \
  -device virtio-blk-pci,drive=drive0 \
  -virtfs "local,path=/nix/store,security_model=none,mount_tag=nix-store,readonly=on" \
  -virtfs "local,path=${WORKTREE},security_model=mapped-xattr,mount_tag=workdir" \
  -kernel "$KERNEL" \
  -initrd "$INITRD" \
  -append "$APPEND" </dev/null &
QEMU_PID=$!

log "Waiting for SSH on 127.0.0.1:${SSH_PORT}…"
SSH_READY=0
for _ in $(seq 1 90); do
  if nc -z 127.0.0.1 "$SSH_PORT" 2>/dev/null; then
    SSH_READY=1
    break
  fi
  if ! kill -0 "$QEMU_PID" 2>/dev/null; then
    log "QEMU exited before SSH came up. Last serial output:"
    tail -n 60 "$SERIAL_LOG" >&2 || true
    fail "VM did not boot. See $SERIAL_LOG for full log."
  fi
  sleep 1
done
if [ "$SSH_READY" -ne 1 ]; then
  log "Timed out waiting for SSH. Last serial output:"
  tail -n 60 "$SERIAL_LOG" >&2 || true
  fail "VM never opened ${SSH_PORT}. See $SERIAL_LOG."
fi

ok "Connecting…"
SSH_OPTS="-p $SSH_PORT -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
SSH_RC=0
ssh $SSH_OPTS -o LogLevel=ERROR \
  -t "${SSH_USER}@127.0.0.1" 'cd /mnt/work && exec $SHELL -l' || SSH_RC=$?

# Diagnostics only when ssh failed AND the VM is still alive — a clean
# `sudo poweroff` from inside also returns non-zero (255: connection closed),
# which isn't worth noisy diagnostics.
if [ "$SSH_RC" -ne 0 ] && [ "$SSH_RC" -ne 130 ] && kill -0 "$QEMU_PID" 2>/dev/null; then
  log "ssh exited $SSH_RC. Re-running with -v for diagnostics:"
  ssh $SSH_OPTS -v -o BatchMode=yes "${SSH_USER}@127.0.0.1" true 2>&1 \
    | sed 's/^/    /' >&2 || true
  log "Tail of VM serial log:"
  tail -n 120 "$SERIAL_LOG" 2>/dev/null | sed 's/^/    /' >&2 || true
fi

# If VM is still up, ask it to power off; otherwise skip (user already did).
if kill -0 "$QEMU_PID" 2>/dev/null; then
  log "Shutting down VM…"
  ssh $SSH_OPTS -o LogLevel=ERROR \
    "${SSH_USER}@127.0.0.1" 'sudo poweroff' 2>/dev/null || true
  # Give QEMU a moment to exit cleanly before cleanup() force-kills.
  for _ in $(seq 1 10); do
    kill -0 "$QEMU_PID" 2>/dev/null || break
    sleep 1
  done
fi
