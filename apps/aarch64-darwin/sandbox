#!/bin/sh -e

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

log()  { printf "${YELLOW}%s${NC}\n" "$*" >&2; }
ok()   { printf "${GREEN}%s${NC}\n" "$*" >&2; }
fail() { printf "${RED}%s${NC}\n" "$*" >&2; exit 1; }

# Locate the user's project. Worktree is created from here; if not in a git
# repo the sandbox refuses to start (no clean trust boundary otherwise).
INVOKED_FROM="${SANDBOX_INVOKED_FROM:-$PWD}"
cd "$INVOKED_FROM"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) \
  || fail "Not in a git repo. cd into one before running sandbox."

# Resolve the flake holding the devvm config. Default to this nix-config repo.
FLAKE="${SANDBOX_FLAKE:-$HOME/nix-config}"

REPO_NAME=$(basename "$REPO_ROOT")
TS=$(date +%Y%m%d-%H%M%S)
SANDBOX_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/nix-sandbox"
WORKTREE="$SANDBOX_ROOT/${REPO_NAME}-${TS}"
BRANCH="sandbox/${TS}"

SSH_PORT="${SANDBOX_SSH_PORT:-2222}"

log "Building devvm…"
INFO=$(nix --extra-experimental-features 'nix-command flakes' build \
  --no-link --print-out-paths \
  "${FLAKE}#nixosConfigurations.devvm.config.system.build.devVmInfo")

KERNEL=$(jq -r .kernel        "$INFO")
INITRD=$(jq -r .initrd        "$INFO")
INIT=$(jq   -r .init          "$INFO")
KPARAMS_FILE=$(jq -r .kernelParamsFile "$INFO")
REGINFO=$(jq -r .regInfo      "$INFO")
SERIAL=$(jq  -r .serialConsole "$INFO")
SSH_USER=$(jq -r .sshUser     "$INFO")

# Also realise the toplevel/initrd/regInfo into the local store.
nix --extra-experimental-features 'nix-command flakes' build --no-link \
  "${FLAKE}#nixosConfigurations.devvm.config.system.build.toplevel" \
  "${FLAKE}#nixosConfigurations.devvm.config.system.build.initialRamdisk"

log "Creating worktree at $WORKTREE on branch $BRANCH"
mkdir -p "$SANDBOX_ROOT"
git -C "$REPO_ROOT" worktree add -b "$BRANCH" "$WORKTREE" >/dev/null

# Per-session state lives next to the worktree but outside it (so the VM
# can't see it). Disk image is the writable overlay for /nix/.rw-store.
STATE_DIR="${WORKTREE}.state"
mkdir -p "$STATE_DIR"
DISK_IMG="$STATE_DIR/devvm.qcow2"
qemu-img create -f qcow2 "$DISK_IMG" 8G >/dev/null

KPARAMS=$(cat "$KPARAMS_FILE")
APPEND="${KPARAMS} init=${INIT} regInfo=${REGINFO} console=${SERIAL},115200n8"

cleanup() {
  if [ -n "${QEMU_PID:-}" ] && kill -0 "$QEMU_PID" 2>/dev/null; then
    kill "$QEMU_PID" 2>/dev/null || true
    wait "$QEMU_PID" 2>/dev/null || true
  fi
  rm -f "$DISK_IMG"
  rmdir "$STATE_DIR" 2>/dev/null || true
  ok ""
  ok "Sandbox session ended."
  ok "Worktree: $WORKTREE  (branch $BRANCH)"
  ok "Diff: git -C \"$REPO_ROOT\" diff $BRANCH"
  ok "Drop: git -C \"$REPO_ROOT\" worktree remove --force \"$WORKTREE\" && git -C \"$REPO_ROOT\" branch -D $BRANCH"
}
trap cleanup EXIT INT TERM

log "Booting QEMU on hvf (port $SSH_PORT → 22)…"

# Keep QEMU args co-located so swapping accel (hvf → vmapple) or fs sharing
# (9p → virtiofs) later is a localised change.
QEMU_BIN="qemu-system-aarch64"
QEMU_MACHINE="virt,accel=hvf,gic-version=3,highmem=on"
QEMU_CPU="host"

"$QEMU_BIN" \
  -name devvm \
  -machine "$QEMU_MACHINE" \
  -cpu "$QEMU_CPU" \
  -m 4096 \
  -smp 4 \
  -nographic \
  -serial mon:stdio \
  -device virtio-rng-pci \
  -netdev "user,id=net0,hostfwd=tcp:127.0.0.1:${SSH_PORT}-:22" \
  -device virtio-net-pci,netdev=net0 \
  -drive "file=${DISK_IMG},if=none,id=drive0,cache=writeback,format=qcow2" \
  -device virtio-blk-pci,drive=drive0 \
  -virtfs "local,path=/nix/store,security_model=none,mount_tag=nix-store,readonly=on" \
  -virtfs "local,path=${WORKTREE},security_model=mapped-xattr,mount_tag=workdir" \
  -kernel "$KERNEL" \
  -initrd "$INITRD" \
  -append "$APPEND" &
QEMU_PID=$!

log "Waiting for SSH on 127.0.0.1:${SSH_PORT}…"
for _ in $(seq 1 90); do
  if nc -z 127.0.0.1 "$SSH_PORT" 2>/dev/null; then
    break
  fi
  if ! kill -0 "$QEMU_PID" 2>/dev/null; then
    fail "QEMU exited before SSH came up."
  fi
  sleep 1
done

ok "Connecting…"
ssh \
  -p "$SSH_PORT" \
  -o StrictHostKeyChecking=no \
  -o UserKnownHostsFile=/dev/null \
  -o LogLevel=ERROR \
  -t "${SSH_USER}@127.0.0.1" 'cd /mnt/work && exec $SHELL -l' \
  || true

log "Shutting down VM…"
ssh \
  -p "$SSH_PORT" \
  -o StrictHostKeyChecking=no \
  -o UserKnownHostsFile=/dev/null \
  -o LogLevel=ERROR \
  "${SSH_USER}@127.0.0.1" 'sudo poweroff' 2>/dev/null || true

# Give QEMU a moment to exit cleanly before cleanup() force-kills.
for _ in $(seq 1 10); do
  kill -0 "$QEMU_PID" 2>/dev/null || break
  sleep 1
done
